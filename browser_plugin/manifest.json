{
  "manifest_version": 3,
  "name": "爱客服采集插件 v2",
  "version": "2.0.0",
  "description": "采集拼多多商家后台聊天消息，推送到爱客服AI客服系统；支持订单同步与浏览足迹采集",
  "permissions": [
    "storage",
    "notifications",
    "activeTab",
    "scripting"
  ],
  "host_permissions": [
    "https://mms.pinduoduo.com/*",
    "http://8.145.43.255:6000/*",
    "http://39.103.98.34:8000/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://mms.pinduoduo.com/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "爱客服采集插件 v2"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
